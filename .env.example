# Copy to .env and adjust. All settings use the KM_ prefix.

# --- database ---
KM_DATABASE_URL=postgresql+asyncpg://km@localhost:5433/km
# for docker compose, set only the password (db host is wired in compose):
KM_DB_PASSWORD=

# --- auth ---
KM_REGISTRATION_OPEN=true        # set false after the team has registered
KM_COOKIE_SECURE=false           # true when served over HTTPS
KM_SESSION_TTL_DAYS=14

# --- semantic search (optional; leave unset to disable) ---
# any OpenAI-compatible endpoint works (OpenAI, Azure, internal LLM gateway, Ollama…)
#KM_EMBEDDINGS_BASE_URL=https://api.openai.com/v1
#KM_EMBEDDINGS_API_KEY=sk-...
#KM_EMBEDDINGS_MODEL=text-embedding-3-small

# --- MCP stdio transport (HTTP transport reads the Authorization header instead) ---
#KM_MCP_TOKEN=kmt_...

# --- misc ---
KM_MAX_UPLOAD_MB=50
KM_PORT=8080                     # host port for docker compose
KM_DATA_DIR=../data                 # host data path when running deploy/docker-compose.yml
